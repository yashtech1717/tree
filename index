<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
    <title>Memory Tree · Mikasa Diary · Emotional Pages</title>
    <!-- Premium Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600&family=Cinzel:wght@400;500;600;700&family=Georgia:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #000000;
            overflow-x: hidden;
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            position: relative;
        }

        /* Cinematic Layered Background */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 50% 30%, rgba(8, 25, 3, 0.85) 0%, #020402 100%);
            z-index: -2;
        }

        body::after {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at center, rgba(29, 233, 59, 0.05) 0%, rgba(0,0,0,0) 70%);
            z-index: -1;
            pointer-events: none;
        }

        .noise-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('data:image/svg+xml;base64,');
            background-repeat: repeat;
            pointer-events: none;
            z-index: 100;
            opacity: 0.18;
            mix-blend-mode: overlay;
        }

        canvas {
            display: block;
            width: 100%;
            height: auto;
            filter: drop-shadow(0 0 25px rgba(29, 233, 59, 0.35));
            cursor: pointer;
            transition: filter 0.4s ease;
        }

        canvas:hover {
            filter: drop-shadow(0 0 35px rgba(29, 233, 59, 0.55));
        }

        /* INTRO - cinematic */
        #intro {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at center, #071a07, #000000);
            display: flex;
            justify-content: center;
            align-items: center;
            text-align: center;
            font-size: clamp(1rem, 5vw, 1.8rem);
            font-weight: 400;
            letter-spacing: 3px;
            color: #e0ffc0;
            text-shadow: 0 0 30px #1de93b;
            z-index: 200;
            backdrop-filter: blur(14px);
            padding: 2rem;
            line-height: 1.6;
            animation: fadeOutCinematic 5s ease-out forwards 3.5s;
            pointer-events: none;
            font-family: 'Cinzel', serif;
        }

        @keyframes fadeOutCinematic {
            0% { opacity: 1; backdrop-filter: blur(14px); }
            100% { opacity: 0; visibility: hidden; backdrop-filter: blur(0); }
        }

        /* DIARY MASTER - Clean Minimal Base */
        .diary-master {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(2, 6, 2, 0.7);
            backdrop-filter: blur(20px);
            z-index: 40;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            animation: fadeInGlass 0.5s ease;
        }

        @keyframes fadeInGlass {
            from { opacity: 0; backdrop-filter: blur(0px); }
            to { opacity: 1; backdrop-filter: blur(20px); }
        }

        /* Main Content - ONLY Person Name & Elegant Space */
        .diary-core {
            text-align: center;
            max-width: 90%;
            width: 100%;
            animation: gentleAppear 0.6s ease;
        }

        @keyframes gentleAppear {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .person-name-large {
            font-size: clamp(2.8rem, 12vw, 5.5rem);
            font-family: 'Cinzel', serif;
            font-weight: 600;
            background: linear-gradient(135deg, #E9FFC2, #A3E67A, #F7D44A);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 0 0 25px rgba(29, 233, 59, 0.3);
            letter-spacing: 4px;
            margin-bottom: 1rem;
        }

        .elegant-hint {
            color: rgba(168, 196, 138, 0.6);
            font-size: 0.85rem;
            letter-spacing: 1px;
            font-weight: 300;
            margin-top: 1.5rem;
        }

        /* ===== FLOATING MENU BUTTON ===== */
        .floating-menu-btn {
            position: fixed;
            bottom: 28px;
            right: 28px;
            width: 60px;
            height: 60px;
            background: rgba(15, 25, 8, 0.85);
            backdrop-filter: blur(16px);
            border-radius: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(29, 233, 59, 0.7);
            box-shadow: 0 8px 20px rgba(0,0,0,0.4), 0 0 0 1px rgba(29,233,59,0.2) inset;
            cursor: pointer;
            z-index: 55;
            transition: all 0.25s ease;
        }

        .floating-menu-btn:hover {
            transform: scale(1.08);
            background: rgba(29, 233, 59, 0.2);
            box-shadow: 0 0 25px #1de93b;
        }

        .floating-menu-btn span {
            font-size: 2rem;
            color: #c0ffa0;
            font-weight: 300;
        }

        /* ===== SMART CONTROL PANEL ===== */
        .control-panel {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(6, 12, 4, 0.92);
            backdrop-filter: blur(32px);
            border-radius: 36px 36px 0 0;
            padding: 1.8rem 1.5rem 2rem;
            transform: translateY(100%);
            transition: transform 0.35s cubic-bezier(0.2, 0.9, 0.4, 1);
            z-index: 60;
            border-top: 1px solid rgba(29, 233, 59, 0.5);
            box-shadow: 0 -10px 40px rgba(0,0,0,0.5);
        }

        .control-panel.open {
            transform: translateY(0);
        }

        .timeline-horizontal {
            display: flex;
            flex-direction: row;
            overflow-x: auto;
            gap: 1rem;
            padding: 0.8rem 0.2rem 1rem;
            scrollbar-width: thin;
        }

        .timeline-horizontal::-webkit-scrollbar { height: 3px; }
        .timeline-horizontal::-webkit-scrollbar-track { background: #1a2a10; border-radius: 10px; }
        .timeline-horizontal::-webkit-scrollbar-thumb { background: #1de93b; border-radius: 10px; }

        .timeline-dot-h {
            display: flex;
            flex-direction: column;
            align-items: center;
            min-width: 70px;
            cursor: pointer;
            transition: 0.2s;
            padding: 0.4rem;
            border-radius: 32px;
            background: rgba(0,0,0,0.3);
        }

        .timeline-dot-h:hover { transform: translateY(-4px); }
        .dot-circle {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            border: 2px solid rgba(255,250,200,0.9);
            box-shadow: 0 0 10px rgba(29,233,59,0.5);
            transition: 0.2s;
        }
        .timeline-dot-h:hover .dot-circle {
            transform: scale(1.08);
            box-shadow: 0 0 20px #1de93b;
        }
        .dot-date { font-size: 0.65rem; color: #b5d49a; margin-top: 6px; font-weight: 500; }

        .stats-mini { font-size: 0.7rem; text-align: center; color: #9bc48b; margin: 0.8rem 0 1rem; }

        .filter-bar {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
            margin: 1rem 0;
            justify-content: center;
        }
        .cat-pill {
            background: rgba(30, 40, 18, 0.8);
            backdrop-filter: blur(8px);
            padding: 5px 16px;
            border-radius: 60px;
            font-size: 0.7rem;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            color: #cdf596;
            border: 1px solid rgba(29, 233, 59, 0.5);
        }
        .cat-pill.active { background: #1de93b; color: #011000; box-shadow: 0 0 14px #1de93b; }

        .panel-actions {
            display: flex;
            gap: 1rem;
            margin-top: 1.2rem;
        }
        .panel-btn {
            flex: 1;
            background: rgba(20, 35, 8, 0.8);
            border: 1px solid rgba(29, 233, 59, 0.6);
            padding: 10px;
            border-radius: 60px;
            color: #e6ffc4;
            font-weight: 600;
            text-align: center;
            cursor: pointer;
            transition: 0.2s;
        }
        .panel-btn:hover { background: #1de93b; color: #021000; box-shadow: 0 0 16px #1de93b; }

        /* Memory Adder - Bottom Sheet */
        .memory-adder {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(6, 10, 3, 0.96);
            backdrop-filter: blur(32px);
            border-radius: 32px 32px 0 0;
            padding: 1.5rem;
            border-top: 1px solid #1de93b;
            display: none;
            z-index: 70;
            transition: transform 0.3s ease;
        }
        .memory-adder.visible { display: block; animation: slideUp 0.3s ease; }
        @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

        textarea, .hashtag-input {
            width: 100%;
            padding: 12px 16px;
            margin: 8px 0;
            border-radius: 28px;
            border: 1px solid rgba(29, 233, 59, 0.5);
            background: rgba(0,0,0,0.7);
            color: #f0f5e0;
            font-family: 'Inter', sans-serif;
        }
        .voice-row { display: flex; gap: 10px; margin: 12px 0; }
        .mini-btn { background: #2a3a1a; padding: 8px 14px; border-radius: 40px; border: none; color: #d4ffb0; cursor: pointer; }
        .btn-save { background: linear-gradient(135deg, #1f3a12, #0e2a06); width: 100%; padding: 12px; border-radius: 60px; color: white; font-weight: bold; border: none; margin-top: 10px; cursor: pointer; }

        /* ===== DYNAMIC NOTEBOOK THEMES ===== */
        .view-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.94);
            backdrop-filter: blur(24px);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 200;
            padding: 1.2rem;
        }

        .notebook-card {
            max-width: 620px;
            width: 100%;
            max-height: 85vh;
            overflow-y: auto;
            border-radius: 28px;
            padding: 2.2rem 2rem;
            box-shadow: 0 35px 55px rgba(0,0,0,0.5), inset 0 0 0 1px rgba(255,245,210,0.8);
            font-family: 'Georgia', serif;
            position: relative;
            transition: background 0.4s ease, box-shadow 0.3s ease, transform 0.2s ease;
            animation: bookUnfold 0.4s cubic-bezier(0.2, 0.9, 0.3, 1);
        }

        @keyframes bookUnfold {
            from { opacity: 0; transform: scale(0.94) translateY(10px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        /* Left margin line (notebook style) */
        .notebook-card::before {
            content: '';
            position: absolute;
            left: 44px;
            top: 20px;
            bottom: 20px;
            width: 2.5px;
            border-radius: 2px;
            transition: background 0.3s ease;
        }

        /* Paper grain overlay */
        .notebook-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMDAiIGhlaWdodD0iMjAwIj48ZmlsdGVyIGlkPSJmIj48ZmVUdXJidWxlbmNlIHR5cGU9ImZyYWN0YWxOb2lzZSIgYmFzZUZyZXF1ZW5jeT0iLjgiLz48L2ZpbHRlcj48cmVjdCB3aWR0aD0iMTAwJSIgaGVpZ2h0PSIxMDAlIiBmaWx0ZXI9InVybCgjZikiIG9wYWNpdHk9IjAuMDYiLz48L3N2Zz4=');
            background-repeat: repeat;
            pointer-events: none;
            border-radius: 28px;
            opacity: 0.3;
            mix-blend-mode: multiply;
        }

        /* LOVE THEME - Romantic Pink */
        .notebook-card.theme-love {
            background: linear-gradient(135deg, #fff0f5 0%, #ffe4e8 100%);
            box-shadow: 0 35px 55px rgba(255, 105, 180, 0.25), inset 0 0 0 1px rgba(255, 182, 193, 0.6);
        }
        .notebook-card.theme-love::before {
            background: linear-gradient(to bottom, #ffb6c1, #ff69b4, #ffb6c1);
            opacity: 0.5;
        }
        .notebook-card.theme-love #modalTitle {
            color: #8b3a5e;
            border-bottom-color: #ffb6c1;
        }
        .notebook-card.theme-love #modalText {
            color: #4a2a3a;
        }

        /* SAD THEME - Melancholy Blue-Grey */
        .notebook-card.theme-sad {
            background: linear-gradient(135deg, #e8eef2 0%, #dce3e8 100%);
            box-shadow: 0 35px 55px rgba(70, 130, 200, 0.2), inset 0 0 0 1px rgba(100, 140, 160, 0.4);
            filter: brightness(0.98);
        }
        .notebook-card.theme-sad::before {
            background: linear-gradient(to bottom, #8ba3b8, #5a7a9a, #8ba3b8);
            opacity: 0.4;
        }
        .notebook-card.theme-sad #modalTitle {
            color: #3a5a6e;
            border-bottom-color: #8ba3b8;
        }
        .notebook-card.theme-sad #modalText {
            color: #3a4a55;
            opacity: 0.92;
        }

        /* PEACE THEME - Calm Green */
        .notebook-card.theme-peace {
            background: linear-gradient(135deg, #eaf7e8 0%, #ddecd8 100%);
            box-shadow: 0 35px 55px rgba(60, 120, 60, 0.2), inset 0 0 0 1px rgba(120, 160, 100, 0.5);
        }
        .notebook-card.theme-peace::before {
            background: linear-gradient(to bottom, #9bc48b, #6a9e5a, #9bc48b);
            opacity: 0.45;
        }
        .notebook-card.theme-peace #modalTitle {
            color: #3a6a3a;
            border-bottom-color: #9bc48b;
        }
        .notebook-card.theme-peace #modalText {
            color: #3a5530;
        }

        /* DEFAULT THEME */
        .notebook-card.theme-default {
            background: #fef7e8;
            background-image: radial-gradient(circle at 25% 40%, rgba(210, 180, 140, 0.08) 2%, transparent 2.5%);
        }
        .notebook-card.theme-default::before {
            background: linear-gradient(to bottom, #e0c8a0, #c0a070, #e0c8a0);
            opacity: 0.65;
        }
        .notebook-card.theme-default #modalTitle {
            color: #4a3724;
            border-bottom-color: #d4b48c;
        }
        .notebook-card.theme-default #modalText {
            color: #2a2418;
        }

        #modalTitle {
            font-family: 'Cinzel', serif;
            font-size: 1.3rem;
            border-bottom: 1px dashed;
            display: inline-block;
            padding-bottom: 0.3rem;
            margin-bottom: 1.2rem;
            letter-spacing: 1px;
            transition: color 0.3s ease;
        }

        #modalText {
            font-size: 1.08rem;
            line-height: 1.85;
            font-weight: 400;
            margin: 1rem 0 1.2rem;
            text-indent: 2rem;
            font-family: 'Georgia', serif;
            word-spacing: 0.5px;
            transition: color 0.3s ease;
        }

        .floating-heart {
            position: fixed;
            pointer-events: none;
            font-size: 1.8rem;
            animation: floatHeart 2.2s ease-out forwards;
            z-index: 300;
        }
        @keyframes floatHeart {
            0% { opacity: 1; transform: translateY(0) scale(0.6); }
            100% { opacity: 0; transform: translateY(-110px) scale(1.3); }
        }

        @media (min-width: 768px) {
            .control-panel { max-width: 460px; left: auto; right: 20px; bottom: 20px; border-radius: 48px; transform: translateX(120%); width: 440px; }
            .control-panel.open { transform: translateX(0); }
            .floating-menu-btn { bottom: 30px; right: 30px; }
            .notebook-card { padding: 2.5rem 2.8rem; }
        }
    </style>
</head>
<body>
<div class="noise-overlay"></div>
<div id="intro">✦ "This tree holds the people we never truly lost,<br>the memories we never forgot." ✦</div>
<canvas id="tree"></canvas>

<div id="diaryMaster" class="diary-master">
    <div class="diary-core">
        <div class="person-name-large" id="diaryPersonName">——</div>
        <div class="elegant-hint" id="emptyHint">✦ tap menu to begin ✦</div>
    </div>
</div>

<div id="floatingMenuBtn" class="floating-menu-btn"><span>◉</span></div>

<div id="controlPanel" class="control-panel">
    <div style="font-size:0.7rem; text-align:center; color:#c0ffa0; letter-spacing:3px; margin-bottom:8px;">✦ THREADS OF TIME ✦</div>
    <div id="timelineHorizontal" class="timeline-horizontal"></div>
    <div class="stats-mini" id="memoryStats"></div>
    <div class="filter-bar" id="filterBar"></div>
    <div class="panel-actions">
        <div id="closeDiaryFromPanel" class="panel-btn">↺ Exit</div>
        <div id="toggleAddFromPanel" class="panel-btn">✍️ + Memory</div>
    </div>
</div>

<div id="memoryAdderPanel" class="memory-adder">
    <h4 style="color:#d6ffa8;">🌱 preserve a moment</h4>
    <textarea id="memoryText" rows="2" placeholder="what happened..."></textarea>
    <input type="text" id="hashTags" class="hashtag-input" placeholder="#happy #sad #love">
    <div class="voice-row">
        <button id="voiceInputBtn" class="mini-btn">🎤 Speak</button>
        <button id="startRecordBtn" class="mini-btn">⏺ Record</button>
        <button id="stopRecordBtn" class="mini-btn">⏹ Stop</button>
    </div>
    <button id="saveNewMemory" class="btn-save">🌿 save forever</button>
</div>

<div id="viewModal" class="view-modal">
    <div class="notebook-card" onclick="event.stopPropagation()">
        <h2 id="modalTitle"></h2>
        <p id="modalText"></p>
        <div id="modalAudio" style="margin: 12px 0;"></div>
        <div id="modalVoiceControls" style="margin: 12px 0;"></div>
        <button id="closeModalBtn" style="background:#d4b48c; color:#2a2418; border:none; padding:8px 24px; border-radius:40px; margin-top:12px; font-family:Georgia; font-weight:bold; cursor:pointer;">close</button>
    </div>
</div>

<script>
    (function(){
        const canvas = document.getElementById("tree");
        const ctx = canvas.getContext("2d");
        let width = window.innerWidth;
        let height = window.innerHeight;
        canvas.width = width;
        canvas.height = height;
        
        const soulNames = ["Elena", "Oliver", "Ivy", "Arthur", "Luna", "Caspian", "Wren", "Nova", "Silas", "Elara", "Milo", "Iris", "Theo", "Aurora"];
        let flowers = [];
        let mouse = { x: width/2, y: height/2 };
        let activeFlower = null;
        let treeData = null;
        let currentActivePerson = "";
        let memoriesDB = {};  
        
        function formatDate(dateObj) { return `${dateObj.getFullYear()}-${String(dateObj.getMonth()+1).padStart(2,'0')}-${String(dateObj.getDate()).padStart(2,'0')}`; }
        
        // ========== ENHANCED PERSONALIZED MEMORY GENERATION ==========
        function generatePersonalizedMemories(personName) {
            const now = new Date();
            const dates = [
                new Date(now),
                new Date(now.getTime() - Math.floor(Math.random() * 5 + 1) * 86400000),
                new Date(now.getTime() - Math.floor(Math.random() * 10 + 3) * 86400000),
                new Date(now.getTime() - Math.floor(Math.random() * 20 + 7) * 86400000)
            ];
            
            const memoryTemplates = [
                { text: (n) => `I still remember the first time we met, ${n}. You had this gentle way of speaking that made me feel like I'd known you for years. That moment changed something in me.`, mood: "happy", tags: ["first-meeting", "destiny", "love"] },
                { text: (n) => `We sat in silence for hours, ${n}. Not the awkward kind — the comfortable one. Just watching the rain trace patterns on the window. Some conversations don't need words.`, mood: "peace", tags: ["silence", "peace", "calm"] },
                { text: (n) => `Last night, I dreamed of you, ${n}. We were laughing about something stupid, and I woke up smiling. I hope you're doing well wherever you are.`, mood: "happy", tags: ["dream", "happy", "memory"] },
                { text: (n) => `You told me your biggest fear is being forgotten. I want you to know — I'll carry your laughter in my heart forever. Some souls leave footprints that never fade.`, mood: "sad", tags: ["deep", "promise", "sad"] },
                { text: (n) => `Remember that stupid argument we had? About something so small I can't even recall. But I remember the hug afterward. The way you held on just a little longer. Forgiveness is beautiful.`, mood: "neutral", tags: ["forgiveness", "growth", "understanding"] },
                { text: (n) => `You looked at the stars and said, "We're all just stardust trying to find our way home." That night, I felt less alone. Thank you for existing, ${n}.`, mood: "peace", tags: ["stars", "hope", "peace"] },
                { text: (n) => `I miss you today, ${n}. Not in a sad way — just a gentle ache. Like a song that reminds me of something beautiful I once had.`, mood: "sad", tags: ["miss", "longing", "sad"] },
                { text: (n) => `You made me laugh until I couldn't breathe. Just a silly joke, but your laugh was contagious. I wish I could bottle that sound.`, mood: "happy", tags: ["laughter", "joy", "happy"] },
                { text: (n) => `"You're stronger than you know," you said. And somehow, I believed it. Your words became armor I still wear.`, mood: "peace", tags: ["strength", "healing", "hope"] },
                { text: (n) => `I made a mistake. A big one. And instead of anger, you offered understanding. That's when I knew — some people are rare treasures.`, mood: "neutral", tags: ["mistake", "forgiveness", "growth"] }
            ];
            
            const shuffled = [...memoryTemplates];
            for (let i = shuffled.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]]; }
            const count = Math.floor(Math.random() * 3) + 3;
            const selected = shuffled.slice(0, count);
            
            return selected.map((template, idx) => ({
                id: Date.now() + Math.random() * 10000 + idx,
                text: template.text(personName),
                dateISO: dates[idx % dates.length].toISOString(),
                dateString: formatDate(dates[idx % dates.length]),
                hashtags: [...template.tags],
                audioData: null,
                mood: template.mood
            }));
        }
        
        function saveToLocal() { localStorage.setItem("memoryTreeMikasaFinal", JSON.stringify(memoriesDB)); }
        function loadFromLocal() {
            const raw = localStorage.getItem("memoryTreeMikasaFinal");
            if (raw) { try { memoriesDB = JSON.parse(raw); } catch(e) { memoriesDB = {}; } }
            if (Object.keys(memoriesDB).length === 0) { for (let name of soulNames) memoriesDB[name] = generatePersonalizedMemories(name); saveToLocal(); }
            else { for (let name of soulNames) if (!memoriesDB[name] || memoriesDB[name].length === 0) memoriesDB[name] = generatePersonalizedMemories(name); saveToLocal(); }
        }
        
        // ========== THEME DETECTION ==========
        function detectMemoryTheme(memory) {
            const text = memory.text.toLowerCase();
            const hashtags = memory.hashtags.map(t => t.toLowerCase());
            const mood = memory.mood;
            if (hashtags.includes('love') || hashtags.includes('romance') || text.includes('love') || text.includes('heart') || text.includes('cherish') || text.includes('forever') || (mood === 'happy' && text.includes('you'))) return 'love';
            if (hashtags.includes('sad') || hashtags.includes('miss') || hashtags.includes('loss') || text.includes('miss') || text.includes('cry') || text.includes('tears') || text.includes('goodbye') || mood === 'sad') return 'sad';
            if (hashtags.includes('calm') || hashtags.includes('healing') || hashtags.includes('nature') || hashtags.includes('peace') || text.includes('calm') || text.includes('peace') || text.includes('heal') || text.includes('sunset')) return 'peace';
            return 'default';
        }
        
        function getMoodEmoji(mood, theme) {
            if (theme === 'love') return '💗';
            if (theme === 'sad') return '🌧';
            if (theme === 'peace') return '🌿';
            const emojis = { happy: '✨', sad: '💧', angry: '⚡', neutral: '📖' };
            return emojis[mood] || '📖';
        }
        
        function applyNotebookTheme(theme) {
            const card = document.querySelector('.notebook-card');
            if (!card) return;
            card.classList.remove('theme-love', 'theme-sad', 'theme-peace', 'theme-default');
            card.classList.add(`theme-${theme}`);
        }
        
        function detectMoodFromText(text){ let t = text.toLowerCase(); if(t.includes("love")||t.includes("happy")||t.includes("joy")) return "happy"; if(t.includes("sad")||t.includes("cry")) return "sad"; if(t.includes("angry")||t.includes("hate")) return "angry"; return "neutral"; }
        function extractHashtags(raw) { let tags=[]; raw.split(/\s+/).forEach(p=>{ if(p.startsWith('#')) tags.push(p.slice(1).toLowerCase()); }); if(tags.length===0) tags.push("memory"); return tags; }
        
        let mediaRecorder = null, audioChunks = [], recordedAudioData = null;
        async function startRecording() { try { const stream = await navigator.mediaDevices.getUserMedia({ audio: true }); mediaRecorder = new MediaRecorder(stream); audioChunks = []; mediaRecorder.ondataavailable = e => audioChunks.push(e.data); mediaRecorder.start(); alert("🎙️ Recording..."); } catch(e) { alert("Microphone needed"); } }
        function stopRecording() { if(mediaRecorder && mediaRecorder.state !== "inactive") { mediaRecorder.onstop = () => { const blob = new Blob(audioChunks, { type: "audio/webm" }); const reader = new FileReader(); reader.readAsDataURL(blob); reader.onloadend = () => { recordedAudioData = reader.result; alert("✅ Audio recorded!"); }; mediaRecorder.stream.getTracks().forEach(track => track.stop()); }; mediaRecorder.stop(); } }
        
        function addMemoryForPerson(person, text, hashtagRaw, audioBase64 = null) {
            if (!text.trim()) return false;
            const now = new Date(); const mood = detectMoodFromText(text);
            const newMemory = { id: Date.now() + Math.random() * 10000, text: text.trim(), dateISO: now.toISOString(), dateString: formatDate(now), hashtags: extractHashtags(hashtagRaw), audioData: audioBase64 || null, mood: mood };
            if (!memoriesDB[person]) memoriesDB[person] = [];
            memoriesDB[person].unshift(newMemory);
            saveToLocal(); createFloatingHeart(); return true;
        }
        function deleteMemory(person, memoryId) { if (memoriesDB[person]) { memoriesDB[person] = memoriesDB[person].filter(m => m.id != memoryId); saveToLocal(); renderHorizontalTimeline(currentActivePerson); updateFilterChips(currentActivePerson); } }
        
        let currentCategoryFilter = "all";
        function renderHorizontalTimeline(person) {
            const container = document.getElementById("timelineHorizontal");
            container.innerHTML = "";
            let memories = memoriesDB[person] || [];
            if (currentCategoryFilter !== "all") memories = memories.filter(m => m.hashtags.includes(currentCategoryFilter));
            if(memories.length === 0) { container.innerHTML = "<div style='color:#9bc48b; text-align:center; width:100%;'>✨ no echoes yet ✨</div>"; document.getElementById("memoryStats").innerHTML = "⚡ 0 memories"; return; }
            memories.forEach((mem) => {
                const dotDiv = document.createElement("div"); dotDiv.className = "timeline-dot-h";
                const circle = document.createElement("div"); circle.className = `dot-circle mood-${mem.mood || "neutral"}`;
                const dateSpan = document.createElement("span"); dateSpan.className = "dot-date"; dateSpan.innerText = mem.dateString;
                dotDiv.appendChild(circle); dotDiv.appendChild(dateSpan);
                dotDiv.onclick = () => openMemoryViewModal(mem, person);
                dotDiv.oncontextmenu = (e) => { e.preventDefault(); if(confirm("delete this memory?")) deleteMemory(person, mem.id); };
                container.appendChild(dotDiv);
            });
            document.getElementById("memoryStats").innerHTML = `📖 ${memories.length} memories · right-click to delete`;
        }
        
        function openMemoryViewModal(memory, person) {
            const theme = detectMemoryTheme(memory);
            applyNotebookTheme(theme);
            const modal = document.getElementById("viewModal");
            const moodEmoji = getMoodEmoji(memory.mood, theme);
            document.getElementById("modalTitle").innerHTML = `${moodEmoji} ${memory.dateString} · ${person}`;
            document.getElementById("modalText").innerHTML = memory.text;
            const audioDiv = document.getElementById("modalAudio");
            if(memory.audioData) audioDiv.innerHTML = `<audio controls src="${memory.audioData}" style="width:100%; margin-top:12px;"></audio>`;
            else audioDiv.innerHTML = `<span style="font-size:12px; color:#8b7a62;">🎙️ no audio</span>`;
            const voiceControls = document.getElementById("modalVoiceControls");
            voiceControls.innerHTML = `<select id="ttsVoiceSelect" style="background:#f0e2ce; color:#3a2a1a; padding:6px; border-radius:20px;"><option value="0">Voice 1</option><option value="1">Voice 2</option><option value="2">Voice 3</option></select>
            <button id="playTTSBtn" class="mini-btn" style="margin-left:8px;">🔊 Read Aloud</button>`;
            modal.style.display = "flex";
            document.getElementById("playTTSBtn").onclick = () => {
                const speech = new SpeechSynthesisUtterance(memory.text);
                const voices = speechSynthesis.getVoices();
                const sel = document.getElementById("ttsVoiceSelect").value;
                if(voices[sel]) speech.voice = voices[sel];
                speech.rate = 0.9; speechSynthesis.cancel(); speechSynthesis.speak(speech);
            };
        }
        
        function updateFilterChips(person) {
            const mems = memoriesDB[person] || [];
            let catSet = new Set(); mems.forEach(m => m.hashtags.forEach(t => catSet.add(t)));
            const categories = Array.from(catSet).sort();
            const filterDiv = document.getElementById("filterBar");
            if(categories.length === 0 && mems.length === 0) { filterDiv.innerHTML = ""; return; }
            filterDiv.innerHTML = "";
            const allChip = document.createElement("div"); allChip.className = `cat-pill ${currentCategoryFilter === "all" ? "active" : ""}`; allChip.innerText = "all"; allChip.onclick = () => { currentCategoryFilter = "all"; renderHorizontalTimeline(person); updateFilterChips(person); }; filterDiv.appendChild(allChip);
            categories.forEach(cat => { const chip = document.createElement("div"); chip.className = `cat-pill ${currentCategoryFilter === cat ? "active" : ""}`; chip.innerText = `#${cat}`; chip.onclick = () => { currentCategoryFilter = cat; renderHorizontalTimeline(person); updateFilterChips(person); }; filterDiv.appendChild(chip); });
        }
        
        function refreshUI(person) { renderHorizontalTimeline(person); updateFilterChips(person); const memCount = (memoriesDB[person] || []).length; document.getElementById("emptyHint").innerHTML = memCount === 0 ? "✦ no memories yet ✦" : "✦ tap menu to explore ✦"; }
        
        function openDiaryLevel100(personName) {
            currentActivePerson = personName; currentCategoryFilter = "all";
            document.getElementById("tree").style.display = "none";
            document.getElementById("diaryMaster").style.display = "flex";
            document.getElementById("diaryPersonName").innerText = personName;
            refreshUI(personName);
            document.getElementById("memoryText").value = ""; document.getElementById("hashTags").value = ""; recordedAudioData = null;
            document.getElementById("memoryAdderPanel").classList.remove("visible"); document.getElementById("memoryAdderPanel").style.display = "none";
            document.getElementById("controlPanel").classList.remove("open");
        }
        function closeDiary() { document.getElementById("diaryMaster").style.display = "none"; document.getElementById("tree").style.display = "block"; if (treeData) { ctx.putImageData(treeData, 0, 0); if (activeFlower) drawNameLabel(activeFlower); } document.getElementById("controlPanel").classList.remove("open"); }
        function toggleControlPanel() { document.getElementById("controlPanel").classList.toggle("open"); }
        function toggleAddMemoryPanel() { const panel = document.getElementById("memoryAdderPanel"); if (panel.style.display === "none" || panel.style.display === "") { panel.style.display = "block"; panel.classList.add("visible"); } else { panel.style.display = "none"; panel.classList.remove("visible"); } }
        function createFloatingHeart() { const master = document.getElementById("diaryMaster"); const heart = document.createElement("div"); heart.className = "floating-heart"; heart.innerHTML = "❤️"; heart.style.left = Math.random() * 80 + 10 + "%"; heart.style.bottom = "20px"; heart.style.position = "fixed"; master.appendChild(heart); setTimeout(() => heart.remove(), 2000); }
        
        // Tree drawing (preserved)
        function drawLand() { ctx.fillStyle = "#071007"; ctx.beginPath(); ctx.moveTo(0, height); ctx.lineTo(width, height); ctx.lineTo(width, height - 45); ctx.lineTo(0, height - 45); ctx.closePath(); ctx.fill(); }
        function drawBranch(x, y, len, angle, lineWidth) { if (len < 8) { if (flowers.length < 45) { let namePick = soulNames[Math.floor(Math.random() * soulNames.length)]; flowers.push({ x: x, y: y, name: namePick }); } return; } ctx.beginPath(); ctx.lineWidth = lineWidth; ctx.strokeStyle = "#1de93b"; ctx.shadowBlur = 12; ctx.shadowColor = "#7eff5e"; let x2 = x + len * Math.cos(angle); let y2 = y - len * Math.sin(angle); ctx.moveTo(x, y); ctx.lineTo(x2, y2); ctx.stroke(); let branchesCount = Math.random() > 0.4 ? 2 : 3; for (let i=0; i<branchesCount; i++) { let newAngle = angle + (Math.random() - 0.5) * 1.1; let newLen = len * (0.65 + Math.random() * 0.25); let newWidth = lineWidth * 0.48; setTimeout(() => { drawBranch(x2, y2, newLen, newAngle, newWidth); }, 75); } }
        function drawNameLabel(flower) { ctx.font = "600 16px 'Cinzel', serif"; ctx.fillStyle = "#f3ffdd"; ctx.shadowBlur = 14; ctx.shadowColor = "#1de93b"; let tw = ctx.measureText(flower.name).width; ctx.fillText(flower.name, flower.x - tw/2, flower.y - 15); ctx.beginPath(); ctx.arc(flower.x, flower.y, 14, 0, Math.PI*2); ctx.fillStyle = "rgba(29,233,59,0.25)"; ctx.fill(); }
        function detectHover() { activeFlower = null; let minDist = 42; for (let f of flowers) { let dx = mouse.x - f.x, dy = mouse.y - f.y, dist = Math.hypot(dx, dy); if (dist < minDist) { minDist = dist; activeFlower = f; } } }
        function redrawCanvas() { if (treeData) { ctx.putImageData(treeData, 0, 0); if (activeFlower) drawNameLabel(activeFlower); } }
        function captureTreeState() { treeData = ctx.getImageData(0, 0, width, height); redrawCanvas(); }
        function handleMouseMove(e) { const rect = canvas.getBoundingClientRect(); const scaleX = canvas.width / rect.width, scaleY = canvas.height / rect.height; mouse.x = Math.min(Math.max(0, (e.clientX - rect.left) * scaleX), width); mouse.y = Math.min(Math.max(0, (e.clientY - rect.top) * scaleY), height); detectHover(); redrawCanvas(); }
        function handleCanvasClick() { if (activeFlower) openDiaryLevel100(activeFlower.name); }
        function handleResize() { width = window.innerWidth; height = window.innerHeight; canvas.width = width; canvas.height = height; flowers = []; ctx.clearRect(0,0,width,height); drawLand(); drawBranch(width/2, height-45, 100, Math.PI/2, 14); setTimeout(() => { captureTreeState(); detectHover(); redrawCanvas(); }, 1500); }
        function initTree() { drawLand(); drawBranch(width/2, height-45, 100, Math.PI/2, 14); setTimeout(() => { captureTreeState(); detectHover(); redrawCanvas(); }, 2800); canvas.addEventListener("mousemove", handleMouseMove); canvas.addEventListener("click", handleCanvasClick); window.addEventListener("resize", () => { setTimeout(handleResize, 100); }); }
        
        function bindEvents() {
            document.getElementById("saveNewMemory").addEventListener("click", () => { if (!currentActivePerson) return; const text = document.getElementById("memoryText").value, hashRaw = document.getElementById("hashTags").value; if (!text.trim()) { alert("write a memory first..."); return; } addMemoryForPerson(currentActivePerson, text, hashRaw, recordedAudioData); document.getElementById("memoryText").value = ""; document.getElementById("hashTags").value = ""; recordedAudioData = null; refreshUI(currentActivePerson); const panel = document.getElementById("memoryAdderPanel"); panel.style.display = "none"; panel.classList.remove("visible"); });
            document.getElementById("closeDiaryFromPanel").addEventListener("click", closeDiary);
            document.getElementById("toggleAddFromPanel").addEventListener("click", toggleAddMemoryPanel);
            document.getElementById("floatingMenuBtn").addEventListener("click", toggleControlPanel);
            document.getElementById("closeModalBtn").addEventListener("click", () => { document.getElementById("viewModal").style.display = "none"; });
            document.getElementById("viewModal").addEventListener("click", () => { document.getElementById("viewModal").style.display = "none"; });
            document.getElementById("voiceInputBtn").addEventListener("click", () => { const SpeechRecog = window.SpeechRecognition || window.webkitSpeechRecognition; if(SpeechRecog){ let recog = new SpeechRecog(); recog.start(); recog.onresult = e => { document.getElementById("memoryText").value += " " + e.results[0][0].transcript; }; } else alert("speech not supported"); });
            document.getElementById("startRecordBtn").addEventListener("click", startRecording);
            document.getElementById("stopRecordBtn").addEventListener("click", stopRecording);
        }
        
        loadFromLocal(); bindEvents(); setTimeout(() => { initTree(); }, 3200);
    })();
</script>
</body>
